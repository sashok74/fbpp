@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

set(fbpp_SUPPORTED_COMPONENTS core schema codegen)
if(NOT fbpp_FIND_COMPONENTS)
    set(fbpp_FIND_COMPONENTS core)
endif()

foreach(_fbpp_component IN LISTS fbpp_FIND_COMPONENTS)
    if(NOT _fbpp_component IN_LIST fbpp_SUPPORTED_COMPONENTS)
        set(fbpp_FOUND FALSE)
        set(fbpp_NOT_FOUND_MESSAGE
            "Unsupported fbpp component: ${_fbpp_component}. Supported components: ${fbpp_SUPPORTED_COMPONENTS}"
        )
        return()
    endif()
endforeach()

# Find required dependencies
list(PREPEND CMAKE_MODULE_PATH "${CMAKE_CURRENT_LIST_DIR}")
find_dependency(Firebird REQUIRED)
find_dependency(nlohmann_json REQUIRED)

set(_fbpp_need_core FALSE)
if("core" IN_LIST fbpp_FIND_COMPONENTS OR "schema" IN_LIST fbpp_FIND_COMPONENTS
        OR "codegen" IN_LIST fbpp_FIND_COMPONENTS)
    set(_fbpp_need_core TRUE)
endif()

if(_fbpp_need_core)
    include("${CMAKE_CURRENT_LIST_DIR}/fbppCoreTargets.cmake")
    set(fbpp_core_FOUND TRUE)
endif()

if("schema" IN_LIST fbpp_FIND_COMPONENTS OR "codegen" IN_LIST fbpp_FIND_COMPONENTS)
    include("${CMAKE_CURRENT_LIST_DIR}/fbppSchemaTargets.cmake")
    set(fbpp_schema_FOUND TRUE)
endif()

if("codegen" IN_LIST fbpp_FIND_COMPONENTS)
    include("${CMAKE_CURRENT_LIST_DIR}/fbppCodegenTargets.cmake")
    set(fbpp_codegen_FOUND TRUE)
endif()

if(NOT TARGET fbpp::fbpp AND TARGET fbpp::fbpp_core)
    add_library(fbpp::fbpp INTERFACE IMPORTED)
    set_property(TARGET fbpp::fbpp PROPERTY
        INTERFACE_LINK_LIBRARIES fbpp::fbpp_core
    )
endif()

if(TARGET fbpp::fbpp_core)
    set_property(TARGET fbpp::fbpp_core APPEND PROPERTY
        INTERFACE_LINK_LIBRARIES Firebird::Firebird
    )

    get_target_property(_fbpp_firebird_include_dirs Firebird::Firebird INTERFACE_INCLUDE_DIRECTORIES)
    if(_fbpp_firebird_include_dirs)
        set_property(TARGET fbpp::fbpp_core APPEND PROPERTY
            INTERFACE_INCLUDE_DIRECTORIES "${_fbpp_firebird_include_dirs}"
        )
    endif()
    unset(_fbpp_firebird_include_dirs)
endif()

# Provide variables for compatibility
set_and_check(fbpp_INCLUDE_DIRS "@PACKAGE_CMAKE_INSTALL_INCLUDEDIR@")
set(fbpp_LIBRARIES fbpp::fbpp_core)

# Check required components
check_required_components(fbpp)
